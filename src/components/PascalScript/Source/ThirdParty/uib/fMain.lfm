  object Memo1: TMemo
    Left = 0
    Height = 252
    Top = 0
    Width = 585
    Align = alClient
    Font.Color = clWindowText
    Font.Height = -13
    Font.Name = 'Courier New'
    Lines.Strings = (
      'program dbtest;'
      'var '
      '  db: TUIBDatabase;'
      '  tr: TUIBTransaction;'
      '  qr: TUIBQuery;'
      'begin'
      '  db := TUIBDatabase.create(nil);'
      '  tr := TUIBTransaction.create(nil);'
      '  qr := TUIBQuery.create(nil);'
      '  try'
      '    db.username := ''SYSDBA'';'
      '    db.password := ''masterkey'';'
      '    db.LibraryName := ''/opt/firebird/lib/libfbclient.so.3.0.13'';'
      '    db.databasename := ''/opt/firebird/examples/empbuild/employee.fdb''; '
      '    db.connected := True;'
      '    tr.database := db;'
      '    qr.transaction := tr;'
      '    qr.sql.text := ''select * from employee'';'
      '    qr.open(true);'
      '    while not qr.eof do'
      '    begin'
      '       writeln(qr.fields.asstring[1]);'
      '       qr.next;'
      '    end;'
      '  finally'
      '    qr.free;'
      '    tr.free;'
      '    db.free;'
      '  end;'
      'end.'
    )
    ParentFont = False
    ScrollBars = ssBoth
    TabOrder = 0
    WordWrap = False
  end
